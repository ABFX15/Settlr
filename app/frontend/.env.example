# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Gasless Relay (Fee Payer)
FEE_PAYER_SECRET_KEY=your-fee-payer-secret-key-base58

# Privy (Embedded Wallets)
# Get these from https://console.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Admin Dashboard Access
# Comma-separated list of wallet addresses authorized to access /admin.
# This is read server-side by lib/admin-auth.ts and gates /api/admin/*.
# Admins sign in by connecting their wallet — there is NO shared secret.
ADMIN_WALLETS=DthkuDsPKR6MqqV28rVSBEqdgnuNtEU6QpLACZ7bCBpD
# (Optional) Same list exposed to the client for UI hints. Safe to publish
# since admin pubkeys are public on-chain anyway.
NEXT_PUBLIC_ADMIN_WALLETS=DthkuDsPKR6MqqV28rVSBEqdgnuNtEU6QpLACZ7bCBpD

# DEPRECATED — legacy shared-secret admin auth. Only set this if you have
# external scripts that haven't migrated to wallet auth yet. New deployments
# should leave this unset.
# ADMIN_SECRET=
# PLATFORM_ADMIN_KEY=

# Range Security - Wallet Risk Screening
# Get your API key from https://app.range.org
# Used to screen merchant wallets before payments to block malicious actors
RANGE_API_KEY=your-range-api-key

# Squads Multisig Vault — receives platform fees
# Set this to YOUR Squads vault PDA before running scripts/init-with-squads.ts
# In production this MUST be a real multisig you control on mainnet.
SQUADS_VAULT_ADDRESS=

# ── Privy (managed-wallet onboarding) ─────────────────────
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── LeafLink integration ──────────────────────────────────
# Per-merchant LeafLink API keys are stored in the leaflink_configs table
# (set via the dashboard Settings → LeafLink panel), not here. These are the
# global/optional knobs:
#
# Shared secret for the internal POST /api/integrations/leaflink/callback
# endpoint (the "invoice paid → push back to LeafLink" hook). Set a strong
# value in production; defaults to a dev secret otherwise.
LEAFLINK_CALLBACK_SECRET=
# Override the LeafLink REST base URL (e.g. a sandbox host). Defaults to
# https://www.leaflink.com/api/v2. Used by tests to target a local server.
# LEAFLINK_API_BASE=
# Public base URL used to build invoice payment links in webhook emails.
NEXT_PUBLIC_APP_URL=https://offbankpay.com

# ── Logging ───────────────────────────────────────────────
# Server-side log verbosity for lib/logger.ts: debug | info | warn | error.
# Defaults to "info". Set to "warn" in production to silence informational
# logs while still surfacing warnings and errors. Errors always print.
LOG_LEVEL=info
