# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Gasless Relay (Fee Payer)
FEE_PAYER_SECRET_KEY=your-fee-payer-secret-key-base58

# Privy (Embedded Wallets)
# Get these from https://console.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Admin Dashboard Access
# Comma-separated list of wallet addresses authorized to access /admin.
# This is read server-side by lib/admin-auth.ts and gates /api/admin/*.
# Admins sign in by connecting their wallet — there is NO shared secret.
ADMIN_WALLETS=DthkuDsPKR6MqqV28rVSBEqdgnuNtEU6QpLACZ7bCBpD
# (Optional) Same list exposed to the client for UI hints. Safe to publish
# since admin pubkeys are public on-chain anyway.
NEXT_PUBLIC_ADMIN_WALLETS=DthkuDsPKR6MqqV28rVSBEqdgnuNtEU6QpLACZ7bCBpD

# DEPRECATED — legacy shared-secret admin auth. Only set this if you have
# external scripts that haven't migrated to wallet auth yet. New deployments
# should leave this unset.
# ADMIN_SECRET=
# PLATFORM_ADMIN_KEY=

# Range Security - Wallet Risk Screening
# Get your API key from https://app.range.org
# Used to screen merchant wallets before payments to block malicious actors
RANGE_API_KEY=your-range-api-key

# ── Sumsub (KYC / KYB identity & business verification) ───
# Powers customer KYC at checkout and the merchant "Verify your business" (KYB)
# step on the Compliance page. Get keys from https://dashboard.sumsub.com
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
# Verification level names — must match the levels you create in the Sumsub
# dashboard. Defaults shown are used if unset.
# SUMSUB_LEVEL_BASIC=basic-kyc-level
# SUMSUB_LEVEL_GAMING=gaming-kyc-level
# SUMSUB_LEVEL_ENHANCED=enhanced-kyc-level
# Business/company verification level for the merchant KYB step. Set this to
# your real Sumsub company level in production; falls back to the basic level.
# SUMSUB_LEVEL_KYB=kyb-level

# ── Helius (server-side checkout payment confirmation) ────
# Confirms checkout payments via webhook (independent of the buyer's browser).
# Without these, the checkout falls back to client-side reference polling.
# 1. Create an API key at https://dev.helius.xyz
# 2. Create a webhook (type: enhanced) pointing at
#    https://offbankpay.com/api/checkout/helius-webhook with a secret auth
#    header, then put that webhook's id + the same secret below.
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
HELIUS_WEBHOOK_AUTH=

# Squads Multisig Vault — receives platform fees
# Set this to YOUR Squads vault PDA before running scripts/init-with-squads.ts
# In production this MUST be a real multisig you control on mainnet.
SQUADS_VAULT_ADDRESS=

# ── Privy (managed-wallet onboarding) ─────────────────────
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── LeafLink integration ──────────────────────────────────
# Per-merchant LeafLink API keys are stored in the leaflink_configs table
# (set via the dashboard Settings → LeafLink panel), not here. These are the
# global/optional knobs:
#
# Shared secret for the internal POST /api/integrations/leaflink/callback
# endpoint (the "invoice paid → push back to LeafLink" hook). Set a strong
# value in production; defaults to a dev secret otherwise.
LEAFLINK_CALLBACK_SECRET=
# Override the LeafLink REST base URL (e.g. a sandbox host). Defaults to
# https://www.leaflink.com/api/v2. Used by tests to target a local server.
# LEAFLINK_API_BASE=
# Public base URL used to build invoice payment links in webhook emails.
NEXT_PUBLIC_APP_URL=https://offbankpay.com

# ── Transak (USD on-ramp — pay invoices by card / bank) ───
# Lets a client pay an invoice in USD; Transak converts to USDC and settles
# it to the merchant's wallet, then a signed webhook marks the invoice paid.
# Get keys from https://dashboard.transak.com
NEXT_PUBLIC_TRANSAK_API_KEY=
NEXT_PUBLIC_TRANSAK_ENVIRONMENT=STAGING
# Secret Transak signs webhooks with (your API secret / access token). The
# webhook at /api/integrations/transak/webhook verifies orders against it.
TRANSAK_WEBHOOK_SECRET=

# ── Off-ramp (USDC → USD settlement) ──────────────────────
# Off-ramping cannabis-derived USDC needs a cannabis-compliant partner (e.g.
# Safe Harbor Financial / a partner credit union). Requests stay "pending"
# until the partner confirms the USD moved via the settlement webhook.
# Comma-separated priority list; "manual" is always the final fallback.
# e.g. "cybrid,manual". "manual" = partner processes off our audit trail + KYB
# and confirms via the webhook.
OFFBANK_OFFRAMP_PROVIDER=manual

# Cybrid B2B off-ramp API (docs.cybrid.xyz) — self-serve sandbox.
# CYBRID_ENVIRONMENT=sandbox
# CYBRID_CLIENT_ID=
# CYBRID_CLIENT_SECRET=
# CYBRID_BANK_GUID=
# Require Sumsub KYB before any off-ramp (set true for production / cannabis).
OFFBANK_REQUIRE_KYB_FOR_OFFRAMP=false
# Shared secret the settlement partner signs the webhook body with
# (HMAC-SHA256, x-offramp-signature header).
OFFRAMP_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────
# Invoices, payout claims, reminders are sent via Resend.
RESEND_API_KEY=
# The platform's VERIFIED sending domain/address (must be verified in Resend).
# Emails go out from here; each carries the merchant's business name as the
# display name and the merchant's address as Reply-To.
RESEND_FROM_EMAIL=invoices@settlr.dev

# ── Logging ───────────────────────────────────────────────
# Server-side log verbosity for lib/logger.ts: debug | info | warn | error.
# Defaults to "info". Set to "warn" in production to silence informational
# logs while still surfacing warnings and errors. Errors always print.
LOG_LEVEL=info
