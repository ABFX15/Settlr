{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "rm -f package-lock.json && npm install --legacy-peer-deps --no-audit --no-fund",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/subscriptions/cron/renew",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/pipeline/process",
      "schedule": "0 2 * * *"
    }
  ]
}
