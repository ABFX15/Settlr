                    className="inline-flex items-center gap-2 rounded-full border border-white/20 px-8 py-3.5 text-sm font-bold text-white transition-all hover:bg-white/10"
                  >
                    Watch Demo
                  </Link>
                </div>
              </div>
            </R>
          </div>
        </section>

        <Footer />
      </div>
    </>
  );
}
