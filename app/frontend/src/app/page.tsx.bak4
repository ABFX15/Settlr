"use client";

import { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import Link from "next/link";
import {
  ArrowRight,
  ChevronDown,
  Zap,
  FileCheck,
  CheckCircle2,
  Shield,
  Mail,
  Ban,
  Eye,
  Receipt,
  Send,
